{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai2m2ia.github.io/api/schemas/catalog.schema.json",
  "title": "AI2M2IA Books Catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "apiBaseUrl", "apiPrefix", "books"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "apiBaseUrl": { "type": "string", "format": "uri" },
    "apiPrefix": { "type": "string", "pattern": "^/" },
    "books": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "format", "manifestUrl", "languages"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "format": { "enum": ["PROSE", "LIGHT_NOVEL", "MANGA", "MANHWA"] },
          "manifestUrl": { "type": "string", "format": "uri" },
          "languages": {
            "type": "array",
            "items": { "type": "string", "minLength": 2 },
            "minItems": 1
          },
          "author": { "type": ["string", "null"] },
          "coverUrl": { "type": ["string", "null"], "format": "uri" },
          "description": { "type": ["string", "null"] },
          "links": {
            "type": ["object", "null"],
            "properties": {
              "youtubeTrailerUrl": { "type": ["string", "null"], "format": "uri" },
              "tiktokSampleUrl": { "type": ["string", "null"], "format": "uri" },
              "amazonKindleUrl": { "type": ["string", "null"], "format": "uri" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
