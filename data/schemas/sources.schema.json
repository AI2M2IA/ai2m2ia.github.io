{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sources Data Schema",
  "description": "Schema for data/sources.json - external references and storefronts",
  "type": "object",
  "required": ["lastUpdated", "sources"],
  "properties": {
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "url", "note"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^source:"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["storefront", "media"]
          },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
