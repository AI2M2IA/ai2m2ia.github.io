{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Media Data Schema",
  "description": "Schema for data/media.json - video and audio content metadata",
  "type": "object",
  "required": ["lastUpdated", "items"],
  "properties": {
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "workFamilyId", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^media:"
          },
          "type": {
            "type": "string",
            "enum": ["tiktok", "youtube", "coming-soon"]
          },
          "workFamilyId": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "thumbnailAlt": {
            "type": "string"
          },
          "tiktokId": {
            "type": "string",
            "pattern": "^\\d{15,20}$"
          },
          "youtubeId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{11}$"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "type": { "const": "tiktok" } }
            },
            "then": {
              "required": ["tiktokId"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "youtube" } }
            },
            "then": {
              "required": ["youtubeId"]
            }
          }
        ]
      }
    }
  }
}
