{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Works Data Schema",
  "description": "Schema for data/works.json - book catalog and character data",
  "type": "object",
  "required": ["lastUpdated", "workFamilies"],
  "properties": {
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format"
    },
    "workFamilies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "genre", "tag", "summary", "route", "coverImage", "coverAlt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique identifier (lowercase, hyphens)"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["series", "standalone", "complete-edition", "adaptation", "wip"]
          },
          "genre": {
            "type": "string",
            "enum": ["progression", "dark-fantasy", "war", "fantasy"]
          },
          "tag": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "route": {
            "type": "string",
            "pattern": "^works/[a-z0-9-]+/$",
            "description": "Route path for work page"
          },
          "coverImage": {
            "type": "string",
            "pattern": "^assets/covers/.+\\.(jpg|png|webp|svg)$"
          },
          "coverAlt": {
            "type": "string",
            "minLength": 1
          },
          "amazonUrl": {
            "type": ["string", "null"],
            "pattern": "^https://www\\.amazon\\.com/"
          },
          "workIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "mediaIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^media:"
            }
          },
          "wip": {
            "type": "boolean"
          },
          "authorshipVariants": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["human", "human-ai"]
            }
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "title", "workFamilyId", "genre", "portraitImage", "portraitAlt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "workFamilyId": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "genre": {
            "type": "string",
            "enum": ["progression", "dark-fantasy", "war", "fantasy"]
          },
          "portraitImage": {
            "type": "string",
            "pattern": "^assets/characters/.+\\.(webp|png|jpg)$"
          },
          "portraitAlt": {
            "type": "string",
            "minLength": 1
          },
          "glowClass": {
            "type": "string",
            "enum": ["glow-gold", "glow-teal", "glow-rose", "glow-amber", "glow-purple"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
